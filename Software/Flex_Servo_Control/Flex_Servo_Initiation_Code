const int FLEX_PIN = A0;

const float VCC = 4.98;
const float R_DIV = 47500.0;

// These will be set during calibration
float STRAIGHT_RESISTANCE = 0;
float BEND_RESISTANCE = 0;

void setup() {
  Serial.begin(9600);
  pinMode(FLEX_PIN, INPUT);

  delay(2000); // Give time to open Serial Monitor

  calibrateSensor();
}

void loop() {
  int flexADC = analogRead(FLEX_PIN);
  float flexV = flexADC * VCC / 1023.0;
  float flexR = R_DIV * (VCC / flexV - 1.0);

  Serial.println("Resistance: " + String(flexR) + " ohms");

  float angle = (flexR - STRAIGHT_RESISTANCE) * (90.0 / (BEND_RESISTANCE - STRAIGHT_RESISTANCE));
  angle = constrain(angle, 0, 90);

  Serial.println("Bend: " + String(angle) + " degrees");
  Serial.println();

  delay(500);
}

// 🔧 Calibration Function
void calibrateSensor() {
  Serial.println("=== FLEX SENSOR CALIBRATION ===");

  // ---- STRAIGHT ----
  Serial.println("Place your hand flat on the table...");
  delay(2000);
  Serial.println("Calibrating straight position (5 seconds)...");

  STRAIGHT_RESISTANCE = averageResistance(5000);

  Serial.println("Straight resistance: " + String(STRAIGHT_RESISTANCE));
  Serial.println();

  delay(2000);

  // ---- BENT ----
  Serial.println("Now bend your fingers to ~90 degrees...");
  delay(2000);
  Serial.println("Calibrating bent position (5 seconds)...");

  BEND_RESISTANCE = averageResistance(5000);

  Serial.println("Bent resistance: " + String(BEND_RESISTANCE));
  Serial.println();

  Serial.println("=== CALIBRATION COMPLETE ===");
  delay(2000);
}

// 📊 Function to average resistance over time
float averageResistance(int duration_ms) {
  unsigned long startTime = millis();
  float total = 0;
  int count = 0;

  while (millis() - startTime < duration_ms) {
    int flexADC = analogRead(FLEX_PIN);
    float flexV = flexADC * VCC / 1023.0;
    float flexR = R_DIV * (VCC / flexV - 1.0);

    total += flexR;
    count++;

    delay(10); // small delay for stability
  }

  return total / count;
}
